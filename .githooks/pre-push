#!/usr/bin/env bash
set -euo pipefail

pkg="${PKG_MANAGER:-npm}"

echo "🔒 Running supply chain audit..."
if [ "$pkg" = "pnpm" ]; then
  $pkg audit --prod
else
  $pkg audit --omit=dev
fi
audit_exit=$?

if [ $audit_exit -ne 0 ]; then
  echo "❌ Vulnerabilities found. Run '$pkg audit' for details."
  echo "   To fix: $pkg audit fix"
  echo "   To push anyway: git push --no-verify"
  exit 1
fi

echo "✅ No vulnerabilities found"
